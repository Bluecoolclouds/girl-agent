modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "vm"
run = ["bash", "-c", "cd girl-agent-src && node_modules/.bin/tsx src/cli.ts --port=5000 --host=0.0.0.0 --no-browser"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd girl-agent-src && node_modules/.bin/tsx src/cli.ts --port=5000 --host=0.0.0.0 --no-browser"
waitForPort = 5000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_anthropic_ai_integrations:2.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 21889
externalPort = 80

[userenv]

[userenv.shared]
GIRL_AGENT_PORT = "3001"

[nix]
channel = "stable-25_05"
